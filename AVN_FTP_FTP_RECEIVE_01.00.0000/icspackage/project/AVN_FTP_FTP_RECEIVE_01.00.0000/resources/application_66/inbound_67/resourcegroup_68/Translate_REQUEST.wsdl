<wsdl:definitions targetNamespace="http://xmlns.oracle.com/cloud/adapter/ediAdapter/Translate_REQUEST" xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/" xmlns:ns0="http://xmlns.oracle.com/cloud/adapter/ediAdapter/Translate_REQUEST/types" xmlns:ns1="http://xmlns.oracle.com/cloud/adapter/ediAdapter/Translate_REQUEST" xmlns="http://schemas.xmlsoap.org/wsdl/soap/" xmlns:plnk="http://schemas.xmlsoap.org/ws/2003/05/partner-link/">  <wsdl:types>    <xs:schema elementFormDefault="qualified" targetNamespace="http://xmlns.oracle.com/b2b/edi/generic/inbound_translate_response" attributeFormDefault="unqualified" xmlns="http://xmlns.oracle.com/b2b/edi/generic/inbound_translate_response" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:ns1="http://xml.oracle.com/adapters/extension">      <xsd:element name="TranslateOutput">        <xsd:complexType>          <xsd:annotation>            <xsd:documentation>Translated canonical format and generated functional acknowledgment.</xsd:documentation>          </xsd:annotation>          <xsd:sequence>            <xsd:element name="msg-group" minOccurs="1" maxOccurs="unbounded" type="message-group-type"/>          </xsd:sequence>        </xsd:complexType>      </xsd:element>      <xsd:complexType name="message-group-type">        <xsd:annotation>          <xsd:appinfo>            <xsd:title>Message Group</xsd:title>          </xsd:appinfo>          <xsd:documentation>A message group contains translated messages generated by this B2B action that require further routing.</xsd:documentation>        </xsd:annotation>        <xsd:sequence>          <xsd:element name="message" minOccurs="0" maxOccurs="unbounded" type="b2b-message-type"/>        </xsd:sequence>        <xsd:attribute name="type" type="xsd:string" use="required">          <xsd:annotation>            <xsd:appinfo>              <xsd:title>Message Group Type</xsd:title>            </xsd:appinfo>            <xsd:documentation>Canonical format group reference</xsd:documentation>          </xsd:annotation>        </xsd:attribute>        <xsd:attribute name="id" type="xsd:string" use="required">          <xsd:annotation>            <xsd:appinfo>              <xsd:title>Message Group ID</xsd:title>            </xsd:appinfo>            <xsd:documentation>A unique ID assigned to this message group</xsd:documentation>          </xsd:annotation>        </xsd:attribute>        <xsd:attribute name="direction" type="xsd:string" use="required">          <xsd:annotation>            <xsd:appinfo>              <xsd:title>Direction</xsd:title>            </xsd:appinfo>            <xsd:documentation>Inbound or Outbound.</xsd:documentation>          </xsd:annotation>        </xsd:attribute>        <xsd:attribute name="trading-partner" type="xsd:string">          <xsd:annotation>            <xsd:appinfo>              <xsd:title>Trading Partner Name</xsd:title>            </xsd:appinfo>            <xsd:documentation>The B2B Trading Partner that was identified as the sender of this message.</xsd:documentation>          </xsd:annotation>        </xsd:attribute>        <xsd:attribute name="document-definition" type="xsd:string">          <xsd:annotation>            <xsd:appinfo>              <xsd:title>B2B Document ID</xsd:title>            </xsd:appinfo>            <xsd:documentation>Identifier of the B2B Document identified based on the inbound agreements for the B2B Trading Partner.</xsd:documentation>          </xsd:annotation>        </xsd:attribute>        <xsd:attribute name="connectivity-properties-code" type="xsd:string">          <xsd:annotation>            <xsd:appinfo>              <xsd:title>Backend Integration ID</xsd:title>            </xsd:appinfo>            <xsd:documentation>For an inbound message that translated successfully, this attribute contains the ID of the backend integration configured in the inbound agreement to route the message for further processing.</xsd:documentation>          </xsd:annotation>        </xsd:attribute>        <xsd:attribute name="connectivity-properties-version" type="xsd:string">          <xsd:annotation>            <xsd:appinfo>              <xsd:title>Backend Integration Version</xsd:title>            </xsd:appinfo>            <xsd:documentation>For an inbound message that translated successfully, this attribute contains the version of the backend integration configured in the inbound agreement to route the message for further processing.</xsd:documentation>          </xsd:annotation>        </xsd:attribute>      </xsd:complexType>      <xsd:complexType name="b2b-message-type">        <xsd:annotation>          <xsd:appinfo>            <xsd:title>B2B Message</xsd:title>          </xsd:appinfo>          <xsd:documentation>A handled message that needs further routing. A successfully translated message is routed to a backend integration, a functional acknowledgment is routed for delivery to the trading partner and an error message routed to an integration for notifications.</xsd:documentation>        </xsd:annotation>        <xsd:attribute name="b2b-message-reference" type="xsd:string" use="required">          <xsd:annotation>            <xsd:appinfo>              <xsd:title>B2B Message Reference</xsd:title>            </xsd:appinfo>            <xsd:documentation>An opaque token that refers to the persisted B2B wire or business message</xsd:documentation>          </xsd:annotation>        </xsd:attribute>      </xsd:complexType>    </xs:schema>    <xs:schema elementFormDefault="qualified" targetNamespace="http://xmlns.oracle.com/b2b/tpm/inbound_translate_request" attributeFormDefault="unqualified" xmlns="http://xmlns.oracle.com/b2b/tpm/inbound_translate_request" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:ns1="http://xml.oracle.com/adapters/extension">      <xsd:element name="TranslateInput">        <xsd:complexType>          <xsd:annotation>            <xsd:documentation>Translate native data to canonical format and generate functional acknowledgment.</xsd:documentation>          </xsd:annotation>          <xsd:sequence>            <xsd:element name="b2b-trading-partner" type="xsd:string" minOccurs="0">              <xsd:annotation>                <xsd:appinfo>                  <xsd:title>B2B Trading Partner</xsd:title>                </xsd:appinfo>                <xsd:documentation>Trading partner name.</xsd:documentation>              </xsd:annotation>            </xsd:element>            <xsd:element name="b2b-message-reference" type="xsd:string" minOccurs="0" maxOccurs="1">              <xsd:annotation>                <xsd:appinfo>                  <xsd:title>B2B Message Reference</xsd:title>                </xsd:appinfo>                <xsd:documentation>An opaque token for the persisted B2B wire or business message. Typically, an adapter endpoint will generate this token and it should be mapped to this element.</xsd:documentation>              </xsd:annotation>            </xsd:element>          </xsd:sequence>        </xsd:complexType>      </xsd:element>    </xs:schema>    <xs:schema elementFormDefault="qualified" targetNamespace="http://xmlns.oracle.com/cloud/adapter/ediAdapter/Translate_REQUEST/types" attributeFormDefault="unqualified" xmlns="http://xmlns.oracle.com/b2b/edi/generic/inbound_translate_response" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:ns1="http://xml.oracle.com/adapters/extension" xmlns:ns2="http://xmlns.oracle.com/b2b/tpm/inbound_translate_request" xmlns:tns0="http://xmlns.oracle.com/cloud/adapter/ediAdapter/Translate_REQUEST/types" xmlns:ns3="http://xmlns.oracle.com/b2b/edi/generic/inbound_translate_response">      <xs:import namespace="http://xmlns.oracle.com/b2b/edi/generic/inbound_translate_response"/>      <xs:import namespace="http://xmlns.oracle.com/b2b/tpm/inbound_translate_request"/>      <xs:element name="execute" type="tns0:executeType"/>      <xs:complexType name="executeType">        <xs:sequence>          <xs:element ref="ns2:TranslateInput"/>        </xs:sequence>      </xs:complexType>      <xs:element name="executeResponse" type="tns0:executeResponseType"/>      <xs:complexType name="executeResponseType">        <xs:sequence>          <xs:element ref="ns3:TranslateOutput"/>        </xs:sequence>      </xs:complexType>    </xs:schema>  </wsdl:types>  <wsdl:message name="executeRequestMessage">    <wsdl:part name="parameters" element="ns0:execute"/>  </wsdl:message>  <wsdl:message name="executeResponseMessage">    <wsdl:part name="parameters" element="ns0:executeResponse"/>  </wsdl:message>  <wsdl:portType name="Translate_REQUESTPortType">    <wsdl:operation name="execute">      <cloud:CloudOperation targetOperation="execute" xmlns:cloud="http://xml.oracle.com/types"/>      <wsdl:input message="ns1:executeRequestMessage"/>      <wsdl:output message="ns1:executeResponseMessage"/>    </wsdl:operation>  </wsdl:portType>  <wsdl:binding name="Translate_REQUESTPortType-binding" type="ns1:Translate_REQUESTPortType">    <binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>    <wsdl:operation name="execute">      <operation soapAction="http://xmlns.oracle.com/cloud/adapter/ediAdapter/Translate_REQUEST/execute"/>      <wsdl:input>        <body use="literal"/>      </wsdl:input>      <wsdl:output>        <body use="literal"/>      </wsdl:output>    </wsdl:operation>  </wsdl:binding>  <plnk:partnerLinkType name="translate_66_inbound_67">    <plnk:role name="Translate_REQUESTPortType">      <plnk:portType name="ns1:Translate_REQUESTPortType"/>    </plnk:role>  </plnk:partnerLinkType></wsdl:definitions>