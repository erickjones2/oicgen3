<adapter-config xsdTargetNamespace="http://xmlns.oracle.com/cloud/adapter/ftp/List_Files_in_FTP_REQUEST/types" name="List_Files_in_FTP_REQUESTPortType" adapter="ftp" wsdlLocation="List_Files_in_FTP_REQUEST.wsdl" xmlns="http://platform.integration.oracle/blocks/adapter/fw/metadata">
  <connection-factory location="ics/FtpAdapter">
    <non-managed-connection managedConnectionFactoryClassName="oracle.tip.adapter.ftp.FTPManagedConnectionFactory">
      <property name="AuthenticationType" value="password"/>
      <property name="ChangeDirectory" value="true"/>
      <property name="DefaultDateFormat" value="MMM d yyyy"/>
      <property name="EnableFIPSMode" value="false"/>
      <property name="FtpConnectionType" value="SFTP"/>
      <property name="Host" value="%%RAJ_FTP2_Host"/>
      <property name="KeepConnections" value="false"/>
      <property name="KeystoreAlgorithm" value="SunX509"/>
      <property name="KeystoreType" value="PKCS12"/>
      <property name="ListParserKey" value="UNIX"/>
      <property name="Port" value="%%RAJ_FTP2_Port"/>
      <property name="PreferredCipherSuite" value="aes128-cbc"/>
      <property name="ProxyHost" value="www-proxy-brmdc.us.oracle.com"/>
      <property name="ProxyPort" value="80"/>
      <property name="ProxyType" value="http"/>
      <property name="RecentDateFormat" value="MMM d HH:mm"/>
      <property name="SecurePort" value="990"/>
      <property name="SftpBlockSize" value="32768"/>
      <property name="TransportProvider" value="http"/>
      <property name="UseFtps" value="false"/>
      <property name="UseProxy" value="true"/>
      <property name="UseSftp" value="%%RAJ_FTP2_UseSftp"/>
      <property name="csfMap" value="oracle.cloud.adapter"/>
      <property name="csfkey" value="c25cf64234e1d1a650f6452d9eec69ea7a85b5d4bef51d6de47fa8b3faf90dea"/>
    </non-managed-connection>
  </connection-factory>
  <endpoint-interaction portType="List_Files_in_FTP_REQUESTPortType" operation="ListFile">
    <interaction-spec className="oracle.tip.adapter.ftp.outbound.FTPListInteractionSpec">
      <property name="ICSFilePull" value="true"/>
      <property name="IncludeFiles" value="LIST_B2B_DUMMY_INCLUDE_FILES"/>
      <property name="Operation" value="ListFile"/>
      <property name="PhysicalDirectory" value="LIST_B2B_DUMMY_DIR"/>
      <property name="pluginVersion" value="20.4.3"/>
      <property name="tradingPartnerMode" value="phase2"/>
    </interaction-spec>
  </endpoint-interaction>
</adapter-config>